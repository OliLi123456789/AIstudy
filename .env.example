# AIstudy — environment variables
# Copy this to .env for local dev. On Vercel, set these in the dashboard.

# Your OpenAI (sk-...) or Anthropic (sk-ant-...) API key.
# The provider is auto-detected by the key prefix.
# In production, set the key via the /admin owner portal (stored in Vercel KV).
# For local dev without Vercel Functions, this env var is the fallback.
VITE_API_KEY=sk-your-key-here

# AI provider: "openai", "deepseek", or "anthropic"
# Required because OpenAI and DeepSeek both use sk- prefix keys.
VITE_AI_PROVIDER=openai

# Admin password for the /admin owner portal.
# Required to set/change the API key in production.
ADMIN_PASSWORD=choose-a-strong-password

# Canvas OAuth2 credentials (optional — for "Sign in with Canvas" button).
# Create a Developer Key on your Canvas instance (Admin → Developer Keys)
# with Redirect URI: https://your-app.vercel.app/api/canvas-oauth?action=callback
# CANVAS_CLIENT_ID=10000000000001
# CANVAS_CLIENT_SECRET=your-secret-here
# CANVAS_URL=https://canvas.institution.edu

